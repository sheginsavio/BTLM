@{
    ViewData["Title"] = "Admin Panel";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">

    <h2>Admin Panel</h2>

    <!-- Users -->
    <div class="card p-3 mt-3">
        <h4>All Users</h4>
        <button class="btn btn-primary" onclick="loadUsers()">Load Users</button>

        <table class="table mt-3">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Username</th>
                    <th>Role</th>
                </tr>
            </thead>
            <tbody id="userTable"></tbody>
        </table>
    </div>

    <!-- Reports -->
    <div class="card p-3 mt-3">
        <h4>Reports</h4>
        <button class="btn btn-warning" onclick="loadTransactions()">View Transactions</button>

        <table class="table mt-3">
            <thead>
                <tr>
                    <th>Transaction ID</th>
                    <th>Account</th>
                    <th>Amount</th>
                </tr>
            </thead>
            <tbody id="reportTable"></tbody>
        </table>
    </div>

</div>

<script>
const token = localStorage.getItem("token");
if (!token) window.location.href = "/Ui/Login";

async function loadUsers() {
    const res = await fetch("/api/user", {
        headers: { "Authorization": "Bearer " + token }
    });

    const users = await res.json();
    const table = document.getElementById("userTable");
    table.innerHTML = "";

    users.forEach(u => {
        table.innerHTML += `
            <tr>
                <td>${u.userId}</td>
                <td>${u.username}</td>
                <td>${u.role}</td>
            </tr>`;
    });
}

async function loadTransactions() {
    const res = await fetch("/api/report/transactions", {
        headers: { "Authorization": "Bearer " + token }
    });

    const data = await res.json();
    const table = document.getElementById("reportTable");
    table.innerHTML = "";

    data.forEach(t => {
        table.innerHTML += `
            <tr>
                <td>${t.transactionId}</td>
                <td>${t.accountId}</td>
                <td>${t.amount}</td>
            </tr>`;
    });
}
</script>
