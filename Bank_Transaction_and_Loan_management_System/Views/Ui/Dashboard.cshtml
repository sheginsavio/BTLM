@{
    ViewData["Title"] = "Dashboard";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">

    <h2>Dashboard</h2>

    <div class="row mt-4">

        <div class="col-md-3">
            <a href="/Ui/Transactions" class="btn btn-primary w-100 mb-3">Transactions</a>
        </div>

        <div class="col-md-3">
            <a href="/Ui/Loans" class="btn btn-warning w-100 mb-3">Loans</a>
        </div>

        <div class="col-md-3">
            <a href="/Ui/AdminPanel" class="btn btn-danger w-100 mb-3">Admin Panel</a>
        </div>

        <div class="col-md-3">
            <button onclick="logout()" class="btn btn-secondary w-100 mb-3">Logout</button>
        </div>

    </div>
</div>

<script>
const token = localStorage.getItem("token");

if (!token) {
    window.location.href = "/Ui/Login";
}

function logout() {
    localStorage.removeItem("token");
    window.location.href = "/Ui/Login";
}
</script>
