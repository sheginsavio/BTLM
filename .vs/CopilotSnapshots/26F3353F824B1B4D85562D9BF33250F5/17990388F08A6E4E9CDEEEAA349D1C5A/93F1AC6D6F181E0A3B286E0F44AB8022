using Microsoft.EntityFrameworkCore;
using Bank_Transaction_and_Loan_management_System.Models;

namespace Bank_Transaction_and_Loan_management_System
{
    public class BankingDbContext : DbContext
    {
        public BankingDbContext(DbContextOptions<BankingDbContext> options) : base(options)
        {
        }

        public DbSet<User> Users { get; set; } = null!;
        public DbSet<Customer> Customers { get; set; } = null!;
        public DbSet<Account> Accounts { get; set; } = null!;
        public DbSet<BankTransaction> BankTransactions { get; set; } = null!;
        public DbSet<Loan> Loans { get; set; } = null!;
        public DbSet<AuditLog> AuditLogs { get; set; } = null!;
        public DbSet<Repayment> Repayments { get; set; } = null!;
    }
}
