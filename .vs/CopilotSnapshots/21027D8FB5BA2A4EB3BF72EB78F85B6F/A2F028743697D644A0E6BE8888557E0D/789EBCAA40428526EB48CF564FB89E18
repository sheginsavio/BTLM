using Microsoft.AspNetCore.Mvc;
using Microsoft.AspNetCore.Authorization;
using Bank_Transaction_and_Loan_management_System.Interfaces;
using Bank_Transaction_and_Loan_management_System.Models;
using System.Security.Claims;

namespace Bank_Transaction_and_Loan_management_System.Controllers
{
    [Route("api/[controller]")]
    [ApiController]
    [Authorize]
    public class UserController : ControllerBase
    {
        private readonly IUserService _userService;
        private readonly ILogger<UserController> _logger;

        public UserController(IUserService userService, ILogger<UserController> logger)
        {
            _userService = userService;
            _logger = logger;
        }

        [Authorize(Roles = "Admin")]
        [HttpGet]
        public async Task<IActionResult> GetAllUsers()
        {
            _logger.LogInformation("Admin user retrieving all users");
            var users = await _userService.GetAllUsersAsync();
            return Ok(users);
        }

        [HttpGet("{id}")]
        public async Task<IActionResult> GetUserById(int id)
        {
            var userId = GetUserIdFromClaims();
            var userRole = GetUserRoleFromClaims();

            // Users can only access their own data unless they are Admin
            if (userId != id && userRole != UserRole.Admin.ToString())
                return Forbid();

            _logger.LogInformation("User {UserId} retrieving user profile for ID {Id}", userId, id);
            var user = await _userService.GetUserByIdAsync(id);
            if (user == null)
                return NotFound(new { message = "User not found." });

            return Ok(user);
        }

        [Authorize(Roles = "Admin")]
        [HttpPut("{id}/role")]
        public async Task<IActionResult> UpdateUserRole(int id, [FromBody] UpdateRoleRequest request)
        {
            if (string.IsNullOrWhiteSpace(request.Role))
                return BadRequest(new { message = "Role is required." });

            _logger.LogInformation("Admin user updating role for user ID {Id} to {Role}", id, request.Role);
            var user = await _userService.UpdateUserRoleAsync(id, request.Role);
            _logger.LogInformation("User role updated successfully for user ID {Id}", id);
            return Ok(new { message = "User role updated successfully.", user });
        }

        private int GetUserIdFromClaims()
        {
            var userIdClaim = User.FindFirst(ClaimTypes.NameIdentifier);
            return userIdClaim != null && int.TryParse(userIdClaim.Value, out var userId) ? userId : 0;
        }

        private string GetUserRoleFromClaims()
        {
            return User.FindFirst(ClaimTypes.Role)?.Value ?? string.Empty;
        }
    }

    public class UpdateRoleRequest
    {
        public string Role { get; set; } = null!;
    }
}