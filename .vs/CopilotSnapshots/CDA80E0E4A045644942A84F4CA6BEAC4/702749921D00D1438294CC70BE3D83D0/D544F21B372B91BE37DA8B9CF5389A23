using System.ComponentModel.DataAnnotations;

namespace Bank_Transaction_and_Loan_management_System.Models.DTOs
{
    public class TransferRequest
    {
        [Required]
        [Range(1, int.MaxValue, ErrorMessage = "FromAccountId must be greater than 0")]
        public int FromAccountId { get; set; }

        [Required]
        [Range(1, int.MaxValue, ErrorMessage = "ToAccountId must be greater than 0")]
        public int ToAccountId { get; set; }

        [Range(0.01, double.MaxValue, ErrorMessage = "Amount must be greater than 0")]
        public decimal Amount { get; set; }
    }
}
