@{
    ViewData["Title"] = "Dashboard";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<script>
    const token = localStorage.getItem("token");
    if (!token) {
        window.location.href = "/Ui/Login";
    }
</script>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="@Url.Action("Dashboard", "Ui")">Bank System</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("Dashboard", "Ui")">Dashboard</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("Transactions", "Ui")">Transactions</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("Loans", "Ui")">Loans</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#" onclick="logout()">Logout</a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <h1>Dashboard</h1>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <h5 class="card-title">Accounts</h5>
                    <p class="card-text">Manage your accounts</p>
                    <a href="@Url.Action("Dashboard", "Ui")" class="btn btn-info btn-sm">View Accounts</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <h5 class="card-title">Transactions</h5>
                    <p class="card-text">View your transactions</p>
                    <a href="@Url.Action("Transactions", "Ui")" class="btn btn-info btn-sm">View Transactions</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <h5 class="card-title">Loans</h5>
                    <p class="card-text">Manage your loans</p>
                    <a href="@Url.Action("Loans", "Ui")" class="btn btn-info btn-sm">View Loans</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function logout() {
        localStorage.removeItem("token");
        window.location.href = "/Ui/Login";
    }
</script>
