@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <h1>Dashboard</h1>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <h5 class="card-title">Accounts</h5>
                    <p class="card-text">Manage your accounts</p>
                    <a href="@Url.Action("Dashboard", "Ui")" class="btn btn-info btn-sm">View Accounts</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <h5 class="card-title">Transactions</h5>
                    <p class="card-text">View your transactions</p>
                    <a href="@Url.Action("Transactions", "Ui")" class="btn btn-info btn-sm">View Transactions</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <h5 class="card-title">Loans</h5>
                    <p class="card-text">Manage your loans</p>
                    <a href="@Url.Action("Loans", "Ui")" class="btn btn-info btn-sm">View Loans</a>
                </div>
            </div>
        </div>
    </div>
</div>
