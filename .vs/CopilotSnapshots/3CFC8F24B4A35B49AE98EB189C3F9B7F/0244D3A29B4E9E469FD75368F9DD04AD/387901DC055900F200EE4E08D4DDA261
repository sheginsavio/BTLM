@{
    ViewData["Title"] = "Admin Panel";
}

<div class="container-fluid mt-5">
    <div class="row">
        <div class="col-md-12">
            <h1>Admin Panel</h1>
            <hr />
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-12">
            <a href="@Url.Action("Dashboard", "Ui")" class="btn btn-secondary">Back to Dashboard</a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>User Management</h5>
                </div>
                <div class="card-body">
                    <p>Manage system users and roles</p>
                    <a href="#" class="btn btn-info btn-sm">Manage Users</a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>Reports</h5>
                </div>
                <div class="card-body">
                    <p>View system reports and analytics</p>
                    <a href="#" class="btn btn-info btn-sm">View Reports</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>Loan Management</h5>
                </div>
                <div class="card-body">
                    <p>Review and manage loan applications</p>
                    <a href="#" class="btn btn-info btn-sm">Manage Loans</a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>System Settings</h5>
                </div>
                <div class="card-body">
                    <p>Configure system settings and parameters</p>
                    <a href="#" class="btn btn-info btn-sm">Settings</a>
                </div>
            </div>
        </div>
    </div>
</div>
