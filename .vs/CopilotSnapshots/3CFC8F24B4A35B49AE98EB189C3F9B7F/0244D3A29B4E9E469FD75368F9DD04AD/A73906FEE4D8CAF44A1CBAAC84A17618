@{
    ViewData["Title"] = "Transactions";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <h1>Transactions</h1>
            <hr />
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <a href="#" class="btn btn-primary btn-block">Deposit</a>
        </div>
        <div class="col-md-3">
            <a href="#" class="btn btn-warning btn-block">Withdraw</a>
        </div>
        <div class="col-md-3">
            <a href="#" class="btn btn-success btn-block">Transfer</a>
        </div>
        <div class="col-md-3">
            <a href="@Url.Action("Dashboard", "Ui")" class="btn btn-secondary btn-block">Back to Dashboard</a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5>Transaction History</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">Loading transactions...</p>
                </div>
            </div>
        </div>
    </div>
</div>
