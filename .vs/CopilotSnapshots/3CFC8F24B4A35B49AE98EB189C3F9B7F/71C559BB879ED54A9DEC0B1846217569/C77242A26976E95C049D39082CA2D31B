@{
    ViewData["Title"] = "Transactions";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">

    <h2>Transactions</h2>

    <!-- Deposit -->
    <div class="card p-3 mt-3">
        <h4>Deposit</h4>
        <input type="number" id="depositAccountId" placeholder="Account ID" class="form-control mb-2" />
        <input type="number" id="depositAmount" placeholder="Amount" class="form-control mb-2" />
        <button class="btn btn-success" onclick="deposit()">Deposit</button>
    </div>

    <!-- Withdraw -->
    <div class="card p-3 mt-3">
        <h4>Withdraw</h4>
        <input type="number" id="withdrawAccountId" placeholder="Account ID" class="form-control mb-2" />
        <input type="number" id="withdrawAmount" placeholder="Amount" class="form-control mb-2" />
        <button class="btn btn-danger" onclick="withdraw()">Withdraw</button>
    </div>

    <!-- Transfer -->
    <div class="card p-3 mt-3">
        <h4>Transfer</h4>
        <input type="number" id="fromAccountId" placeholder="From Account ID" class="form-control mb-2" />
        <input type="number" id="toAccountId" placeholder="To Account ID" class="form-control mb-2" />
        <input type="number" id="transferAmount" placeholder="Amount" class="form-control mb-2" />
        <button class="btn btn-primary" onclick="transfer()">Transfer</button>
    </div>

    <!-- View My Transactions -->
    <button class="btn btn-info mt-3" onclick="loadMyTransactions()">View My Transactions</button>

    <table class="table mt-3">
        <thead>
            <tr>
                <th>ID</th>
                <th>Account</th>
                <th>Type</th>
                <th>Amount</th>
            </tr>
        </thead>
        <tbody id="transactionTable"></tbody>
    </table>

</div>

<script>
const token = localStorage.getItem("token");

if (!token) {
    window.location.href = "/Ui/Login";
}

async function deposit() {
    await callApi("/api/transaction/deposit", {
        accountId: depositAccountId.value,
        amount: depositAmount.value
    });
}

async function withdraw() {
    await callApi("/api/transaction/withdraw", {
        accountId: withdrawAccountId.value,
        amount: withdrawAmount.value
    });
}

async function transfer() {
    await callApi("/api/transaction/transfer", {
        fromAccountId: fromAccountId.value,
        toAccountId: toAccountId.value,
        amount: transferAmount.value
    });
}

async function callApi(url, body) {
    const response = await fetch(url, {
        method: "POST",
        headers: {
            "Content-Type": "application/json",
            "Authorization": "Bearer " + token
        },
        body: JSON.stringify(body)
    });

    const data = await response.json();
    alert(data.message || "Success");
}

async function loadMyTransactions() {
    const res = await fetch("/api/transaction/my-transactions", {
        headers: { "Authorization": "Bearer " + token }
    });

    const data = await res.json();
    const table = document.getElementById("transactionTable");
    table.innerHTML = "";

    data.forEach(t => {
        table.innerHTML += `
            <tr>
                <td>${t.transactionId}</td>
                <td>${t.accountId}</td>
                <td>${t.transactionType}</td>
                <td>${t.amount}</td>
            </tr>`;
    });
}
</script>
