@{
    ViewData["Title"] = "Loans";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<script>
    const token = localStorage.getItem("token");
    if (!token) {
        window.location.href = "/Ui/Login";
    }
</script>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="@Url.Action("Dashboard", "Ui")">Bank System</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("Dashboard", "Ui")">Dashboard</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("Transactions", "Ui")">Transactions</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("Loans", "Ui")">Loans</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#" onclick="logout()">Logout</a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <h1>Loans</h1>
            <hr />
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <button class="btn btn-primary w-100" data-bs-toggle="modal" data-bs-target="#loanModal">Apply for Loan</button>
        </div>
        <div class="col-md-6">
            <a href="@Url.Action("Dashboard", "Ui")" class="btn btn-secondary w-100">Back to Dashboard</a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5>My Loans</h5>
                </div>
                <div class="card-body">
                    <table class="table" id="loansTable">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Amount</th>
                                <th>Status</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody id="loansBody">
                            <tr><td colspan="4" class="text-center text-muted">Loading loans...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Loan Application Modal -->
<div class="modal fade" id="loanModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Apply for Loan</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Amount</label>
                    <input type="number" class="form-control" id="loanAmount" step="0.01" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Duration (Months)</label>
                    <input type="number" class="form-control" id="loanDuration" required>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="applyLoan()">Apply</button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    const token = localStorage.getItem("token");

    function logout() {
        localStorage.removeItem("token");
        window.location.href = "/Ui/Login";
    }

    async function loadLoans() {
        const response = await fetch("/api/loan/my-loans", {
            headers: {
                "Authorization": "Bearer " + token
            }
        });

        if (response.ok) {
            const loans = await response.json();
            const tbody = document.getElementById("loansBody");
            tbody.innerHTML = "";

            if (loans.length === 0) {
                tbody.innerHTML = "<tr><td colspan='4' class='text-center text-muted'>No loans found</td></tr>";
            } else {
                loans.forEach(l => {
                    tbody.innerHTML += `<tr><td>${l.id}</td><td>${l.amount}</td><td>${l.status}</td><td>${new Date(l.createdAt).toLocaleDateString()}</td></tr>`;
                });
            }
        } else {
            alert("Failed to load loans");
        }
    }

    async function applyLoan() {
        const amount = document.getElementById("loanAmount").value;
        const duration = document.getElementById("loanDuration").value;

        const response = await fetch("/api/loan/apply", {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "Authorization": "Bearer " + token
            },
            body: JSON.stringify({ amount, duration })
        });

        if (response.ok) {
            alert("Loan application submitted successfully");
            bootstrap.Modal.getInstance(document.getElementById("loanModal")).hide();
            loadLoans();
        } else {
            const data = await response.json();
            alert(data.message || "Loan application failed");
        }
    }

    loadLoans();
</script>
