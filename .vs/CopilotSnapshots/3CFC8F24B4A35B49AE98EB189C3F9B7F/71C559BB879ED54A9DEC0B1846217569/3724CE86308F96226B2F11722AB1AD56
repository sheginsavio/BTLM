@{
    ViewData["Title"] = "Loans";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">

    <h2>Loans</h2>

    <!-- Apply Loan -->
    <div class="card p-3 mt-3">
        <h4>Apply Loan</h4>
        <input type="number" id="customerId" placeholder="Customer ID" class="form-control mb-2" />
        <input type="number" id="loanAmount" placeholder="Loan Amount" class="form-control mb-2" />
        <input type="number" id="interestRate" placeholder="Interest Rate" class="form-control mb-2" />
        <button class="btn btn-primary" onclick="applyLoan()">Apply</button>
    </div>

    <!-- View My Loans -->
    <div class="card p-3 mt-3">
        <h4>My Loans</h4>
        <button class="btn btn-success" onclick="getLoans()">Load Loans</button>

        <table class="table mt-3">
            <thead>
                <tr>
                    <th>Loan ID</th>
                    <th>Amount</th>
                    <th>Interest</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody id="loanTable"></tbody>
        </table>
    </div>

</div>

<script>
const token = localStorage.getItem("token");
if (!token) window.location.href = "/Ui/Login";

async function applyLoan() {
    const response = await fetch("/api/loan/apply", {
        method: "POST",
        headers: {
            "Content-Type": "application/json",
            "Authorization": "Bearer " + token
        },
        body: JSON.stringify({
            customerId: customerId.value,
            loanAmount: loanAmount.value,
            interestRate: interestRate.value
        })
    });

    const data = await response.json();
    alert(data.message);
}

async function getLoans() {
    const response = await fetch("/api/loan/my-loans", {
        headers: {
            "Authorization": "Bearer " + token
        }
    });

    const loans = await response.json();
    const table = document.getElementById("loanTable");
    table.innerHTML = "";

    loans.forEach(l => {
        table.innerHTML += `
            <tr>
                <td>${l.loanId}</td>
                <td>${l.loanAmount}</td>
                <td>${l.interestRate}</td>
                <td>${l.loanStatus}</td>
            </tr>`;
    });
}
</script>
