@model MVC_BANK_FINAL_C.Models.ViewModels.AccountRequestViewModel
@{
    ViewData["Title"] = "Reject Account Request";
}

<div class="d-flex justify-content-center">
    <div class="card shadow-sm w-100" style="max-width:500px;">
        <div class="card-header bg-danger text-white fw-semibold">
            Reject Account Request
        </div>
        <div class="card-body p-4">

            <div class="mb-3">
                <label class="form-label fw-semibold text-muted small">Customer</label>
                <p class="mb-0 fw-semibold">@Model.CustomerName</p>
            </div>
            <div class="mb-4">
                <label class="form-label fw-semibold text-muted small">Account Type Requested</label>
                <p class="mb-0 fw-semibold">@Model.AccountType</p>
            </div>

            <hr />

            <form asp-action="Reject" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <input type="hidden" asp-for="RequestId" />
                <input type="hidden" asp-for="CustomerId" />
                <input type="hidden" asp-for="CustomerName" />
                <input type="hidden" asp-for="AccountType" />
                <input type="hidden" asp-for="Status" />

                <div class="mb-3">
                    <label asp-for="RejectionReason" class="form-label fw-semibold"></label>
                    <textarea asp-for="RejectionReason" class="form-control" rows="3"
                              placeholder="Provide a reason for rejection..."></textarea>
                    <span asp-validation-for="RejectionReason" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-danger fw-semibold"
                            onclick="return confirm('Confirm rejection of this account request?')">
                        Confirm Rejection
                    </button>
                    <a asp-action="PendingRequests" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
