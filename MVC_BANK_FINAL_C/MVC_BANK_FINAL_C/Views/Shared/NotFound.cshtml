@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 — Page Not Found</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />
</head>
<body class="min-vh-100 d-flex align-items-center justify-content-center"
      style="background-color:#f8f9fa;">

    <div class="card shadow-lg rounded-4 p-5 text-center" style="max-width:480px;width:100%;">

        <!-- Vault SVG icon -->
        <div class="d-flex justify-content-center">
            <svg width="120" height="120" viewBox="0 0 120 120"
                 xmlns="http://www.w3.org/2000/svg" aria-hidden="true">

                <!-- Vault door outer frame -->
                <circle cx="60" cy="60" r="56"
                        fill="none" stroke="#0d6efd" stroke-width="5" />

                <!-- Vault door inner plate -->
                <circle cx="60" cy="60" r="42"
                        fill="none" stroke="#0d6efd" stroke-width="3" />

                <!-- 6 locking bolts evenly spaced around inner circle -->
                <circle cx="60"  cy="18"  r="5" fill="#0d6efd" />
                <circle cx="96"  cy="39"  r="5" fill="#0d6efd" />
                <circle cx="96"  cy="81"  r="5" fill="#0d6efd" />
                <circle cx="60"  cy="102" r="5" fill="#0d6efd" />
                <circle cx="24"  cy="81"  r="5" fill="#0d6efd" />
                <circle cx="24"  cy="39"  r="5" fill="#0d6efd" />

                <!-- Combination lock wheel (outer ring) -->
                <circle cx="60" cy="60" r="16"
                        fill="none" stroke="#0d6efd" stroke-width="2.5" />

                <!-- Lock wheel tick marks at 12, 3, 6, 9 o'clock -->
                <line x1="60" y1="44" x2="60" y2="49"
                      stroke="#0d6efd" stroke-width="2" stroke-linecap="round" />
                <line x1="76" y1="60" x2="71" y2="60"
                      stroke="#0d6efd" stroke-width="2" stroke-linecap="round" />
                <line x1="60" y1="76" x2="60" y2="71"
                      stroke="#0d6efd" stroke-width="2" stroke-linecap="round" />
                <line x1="44" y1="60" x2="49" y2="60"
                      stroke="#0d6efd" stroke-width="2" stroke-linecap="round" />

                <!-- Centre pin of the lock -->
                <circle cx="60" cy="60" r="4" fill="#0d6efd" />

                <!-- Handle bar on the right side of the vault door -->
                <rect x="97" y="52" width="10" height="16"
                      rx="5" ry="5"
                      fill="none" stroke="#0d6efd" stroke-width="3" />
            </svg>
        </div>

        <!-- 404 heading -->
        <div class="display-1 fw-bold text-primary mt-3">404</div>
        <h4 class="fw-semibold text-dark mt-1">Page Not Found</h4>
        <p class="text-muted small mb-1">
            The page you are looking for doesn't exist or has been moved.
        </p>
        <p class="text-muted small">
            Please return to the dashboard or go back.
        </p>

        <!-- Action buttons -->
        <div class="mt-4 gap-2 d-flex justify-content-center">
            <a href="/Home/Index" class="btn btn-primary">Go to Dashboard</a>
            <button type="button" class="btn btn-outline-secondary"
                    onclick="history.back()">Go Back</button>
        </div>

    </div>

</body>
</html>
