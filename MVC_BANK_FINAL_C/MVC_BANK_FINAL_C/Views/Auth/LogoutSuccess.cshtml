@{
    ViewData["Title"] = "Logged Out";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="card auth-card text-center">
    <div class="card-body p-5">
        <div class="mb-3" style="font-size:4rem;">&#128274;</div>
        <h4 class="fw-bold mb-2">Signed Out</h4>
        <div class="alert alert-success py-2">
            You have been successfully logged out.
        </div>
        <p class="text-muted small mb-4">Thank you for using BankingSystem. Your session has been cleared.</p>
        <a asp-controller="Auth" asp-action="Login" class="btn btn-primary btn-lg px-5 fw-semibold">
            Back to Login
        </a>
    </div>
</div>
