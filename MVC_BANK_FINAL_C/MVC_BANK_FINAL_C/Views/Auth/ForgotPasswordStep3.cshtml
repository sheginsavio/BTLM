@model MVC_BANK_FINAL_C.Models.ViewModels.ForgotPasswordStep3ViewModel
@{
    ViewData["Title"] = "Forgot Password — Step 3";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="card auth-card" style="max-width:440px;">
    <div class="card-header bg-success text-white text-center py-3">
        <h5 class="mb-0 fw-bold">Forgot Password &mdash; Step 3 of 3</h5>
    </div>
    <div class="card-body p-4">

        <div class="mb-3">
            <div class="progress" style="height:8px;">
                <div class="progress-bar bg-success" role="progressbar"
                     style="width:100%;" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100">
                </div>
            </div>
            <div class="text-end text-muted small mt-1">Step 3 of 3</div>
        </div>

        <div class="text-center mb-3">
            <span style="font-size:2.5rem; color:#198754;">&#10003;</span>
        </div>
        <p class="text-center text-muted small mb-3">
            Identity verified! Please set your new password.
        </p>

        <form asp-action="ForgotPasswordStep3" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

            <input type="hidden" asp-for="Username" />

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                <input asp-for="NewPassword" class="form-control form-control-lg"
                       placeholder="New password" autocomplete="new-password" />
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                <input asp-for="ConfirmPassword" class="form-control form-control-lg"
                       placeholder="Confirm new password" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-success btn-lg fw-semibold">Reset Password</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
