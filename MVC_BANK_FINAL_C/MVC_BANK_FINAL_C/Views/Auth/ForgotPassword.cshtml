@model MVC_BANK_FINAL_C.Models.ViewModels.ForgotPasswordStep1ViewModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="card auth-card" style="max-width:440px;">
    <div class="card-header bg-primary text-white text-center py-3">
        <h5 class="mb-0 fw-bold">Forgot Password &mdash; Step 1 of 3</h5>
    </div>
    <div class="card-body p-4">

        <div class="mb-3">
            <div class="progress" style="height:8px;">
                <div class="progress-bar bg-primary" role="progressbar"
                     style="width:33%;" aria-valuenow="33" aria-valuemin="0" aria-valuemax="100">
                </div>
            </div>
            <div class="text-end text-muted small mt-1">Step 1 of 3</div>
        </div>

        <p class="text-muted small mb-3">Enter your username to begin password reset.</p>

        <form asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

            <div class="mb-3">
                <label asp-for="Username" class="form-label fw-semibold"></label>
                <input asp-for="Username" class="form-control form-control-lg"
                       placeholder="Enter your username" autocomplete="username" />
                <span asp-validation-for="Username" class="text-danger small"></span>
            </div>

            <div class="d-grid mb-3">
                <button type="submit" class="btn btn-primary btn-lg fw-semibold">Continue</button>
            </div>
        </form>

        <div class="text-center">
            <a asp-action="Login" class="text-decoration-none small">&larr; Back to Login</a>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
