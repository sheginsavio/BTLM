@model MVC_BANK_FINAL_C.Models.ViewModels.ForgotPasswordStep2ViewModel
@{
    ViewData["Title"] = "Forgot Password — Step 2";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="card auth-card" style="max-width:440px;">
    <div class="card-header bg-primary text-white text-center py-3">
        <h5 class="mb-0 fw-bold">Forgot Password &mdash; Step 2 of 3</h5>
    </div>
    <div class="card-body p-4">

        <div class="mb-3">
            <div class="progress" style="height:8px;">
                <div class="progress-bar bg-primary" role="progressbar"
                     style="width:66%;" aria-valuenow="66" aria-valuemin="0" aria-valuemax="100">
                </div>
            </div>
            <div class="text-end text-muted small mt-1">Step 2 of 3</div>
        </div>

        <div class="alert alert-info small mb-3">
            <strong>Your Security Question:</strong><br />
            @Model.SecurityQuestion
        </div>

        <form asp-action="ForgotPasswordStep2" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

            <input type="hidden" asp-for="Username" />
            <input type="hidden" asp-for="SecurityQuestion" />

            <div class="mb-3">
                <label asp-for="SecurityAnswer" class="form-label fw-semibold"></label>
                <input asp-for="SecurityAnswer" class="form-control form-control-lg"
                       placeholder="Enter your answer" autocomplete="off" />
                <div class="form-text text-muted">Answer is not case-sensitive.</div>
                <span asp-validation-for="SecurityAnswer" class="text-danger small"></span>
            </div>

            <div class="d-grid mb-3">
                <button type="submit" class="btn btn-primary btn-lg fw-semibold">Verify Answer</button>
            </div>
        </form>

        <div class="text-center">
            <a asp-action="ForgotPassword" class="text-decoration-none small">&larr; Back to Step 1</a>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
