@model MVC_BANK_FINAL_C.Models.ViewModels.AdminResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="d-flex justify-content-center">
    <div class="card shadow-sm w-100" style="max-width:500px;">
        <div class="card-header bg-warning text-dark fw-semibold">
            Reset Password
        </div>
        <div class="card-body p-4">

            <div class="mb-3">
                <label class="form-label fw-semibold text-muted small">Username</label>
                <p class="mb-0 fw-semibold">@Model.Username</p>
            </div>
            <div class="mb-4">
                <label class="form-label fw-semibold text-muted small">Role</label>
                <p class="mb-0">@Model.Role</p>
            </div>

            <form asp-action="ResetPassword" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="Username" />
                <input type="hidden" asp-for="Role" />

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                    <input asp-for="NewPassword" class="form-control" placeholder="New password" autocomplete="new-password" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirm new password" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <hr />

                <div class="mb-3">
                    <label asp-for="SecurityQuestion" class="form-label fw-semibold"></label>
                    <input asp-for="SecurityQuestion" class="form-control"
                           placeholder="e.g. What was your first pet's name?" />
                    <span asp-validation-for="SecurityQuestion" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="SecurityAnswer" class="form-label fw-semibold"></label>
                    <input asp-for="SecurityAnswer" class="form-control"
                           placeholder="Security answer" autocomplete="off" />
                    <div class="form-text text-muted">Leave blank to keep the existing security answer.</div>
                    <span asp-validation-for="SecurityAnswer" class="text-danger small"></span>
                </div>

                <div class="alert alert-warning small">
                    &#9888; User will be forced to change this password on next login.
                </div>

                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-warning fw-semibold">Reset Password</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
