@model MVC_BANK_FINAL_C.Models.ViewModels.CreateUserViewModel
@{
    ViewData["Title"] = "Create Staff User";
}

<div class="d-flex justify-content-center">
    <div class="card shadow-sm w-100" style="max-width:500px;">
        <div class="card-header bg-primary text-white fw-semibold">
            Create Staff User
        </div>
        <div class="card-body p-4">

            <div class="alert alert-info small mb-3">
                User will be prompted to change their password on first login.
            </div>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <div class="mb-3">
                    <label asp-for="Username" class="form-label fw-semibold"></label>
                    <input asp-for="Username" class="form-control" placeholder="Enter username" autocomplete="off" />
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold"></label>
                    <input asp-for="Password" class="form-control" placeholder="Temporary password" autocomplete="new-password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Role" class="form-label fw-semibold"></label>
                    <select asp-for="Role" class="form-select">
                        <option value="Teller">Teller</option>
                        <option value="LoanOfficer">LoanOfficer</option>
                        <option value="Auditor">Auditor</option>
                    </select>
                    <span asp-validation-for="Role" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary fw-semibold">Create User</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
