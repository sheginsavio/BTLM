@model MVC_BANK_FINAL_C.Models.Entities.Loan
@{
    ViewData["Title"] = "Loan Details";
    var sessionRole = Context.Session.GetString("UserRole") ?? "";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Loan Details</h2>
    <div>
        @if ((sessionRole == "Admin" || sessionRole == "LoanOfficer") && Model.LoanStatus == MVC_BANK_FINAL_C.Data.LoanStatus.APPLIED)
        {
            <a asp-action="Approve" asp-route-id="@Model.LoanId" class="btn btn-warning me-2">Approve / Reject</a>
        }
        <a asp-action="Index" class="btn btn-outline-dark">Back to List</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white fw-semibold">Loan Information</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Loan ID</dt>
                    <dd class="col-sm-7">@Model.LoanId</dd>

                    <dt class="col-sm-5">Customer</dt>
                    <dd class="col-sm-7">@(Model.Customer?.Name ?? "-")</dd>

                    <dt class="col-sm-5">Loan Type</dt>
                    <dd class="col-sm-7"><span class="badge bg-info text-dark">@Model.LoanType</span></dd>

                    <dt class="col-sm-5">Loan Amount</dt>
                    <dd class="col-sm-7 fw-semibold">@Model.LoanAmount.ToString("C")</dd>

                    <dt class="col-sm-5">Interest Rate</dt>
                    <dd class="col-sm-7">@Model.InterestRate%</dd>

                    <dt class="col-sm-5">Tenure</dt>
                    <dd class="col-sm-7">@Model.Tenure year@(Model.Tenure != 1 ? "s" : "")</dd>

                    <dt class="col-sm-5">Monthly EMI</dt>
                    <dd class="col-sm-7 fw-bold text-success fs-6">@Model.MonthlyEMI.ToString("C")</dd>

                    <dt class="col-sm-5">Status</dt>
                    <dd class="col-sm-7">
                        <span class="badge @(Model.LoanStatus == MVC_BANK_FINAL_C.Data.LoanStatus.APPROVED ? "bg-success" : Model.LoanStatus == MVC_BANK_FINAL_C.Data.LoanStatus.REJECTED ? "bg-danger" : "bg-secondary")">
                            @Model.LoanStatus
                        </span>
                    </dd>
                </dl>
            </div>
        </div>

        @if (Model.LoanStatus == MVC_BANK_FINAL_C.Data.LoanStatus.APPROVED)
        {
            <div class="card shadow-sm mt-3">
                <div class="card-body bg-light">
                    <p class="fw-semibold mb-2">Total Repayment Breakdown</p>
                    @{
                        decimal si    = Model.LoanAmount * Model.InterestRate * Model.Tenure / 100m;
                        decimal total = Model.LoanAmount + si;
                    }
                    <dl class="row mb-0 small">
                        <dt class="col-sm-6">Principal</dt>
                        <dd class="col-sm-6">@Model.LoanAmount.ToString("C")</dd>
                        <dt class="col-sm-6">Total Interest</dt>
                        <dd class="col-sm-6 text-danger">@si.ToString("C")</dd>
                        <dt class="col-sm-6 fw-bold">Total Payable</dt>
                        <dd class="col-sm-6 fw-bold">@total.ToString("C")</dd>
                        <dt class="col-sm-6">Monthly EMI</dt>
                        <dd class="col-sm-6 text-success fw-semibold">@Model.MonthlyEMI.ToString("C")</dd>
                    </dl>
                </div>
            </div>

            <div class="mt-3 d-grid gap-2">
                @if (sessionRole == "Admin" || sessionRole == "LoanOfficer")
                {
                    <a asp-controller="Repayment" asp-action="Record" asp-route-loanId="@Model.LoanId" class="btn btn-outline-success">
                        Record Repayment
                    </a>
                }
                <a asp-controller="Repayment" asp-action="Interest" asp-route-loanId="@Model.LoanId" class="btn btn-outline-warning">
                    View Interest Calculation
                </a>
                <a asp-controller="Repayment" asp-action="Index" asp-route-loanId="@Model.LoanId" class="btn btn-outline-info">
                    Repayment History
                </a>
            </div>
        }
    </div>

    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white fw-semibold">Repayment History</div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Date</th>
                            <th>Amount Paid</th>
                            <th>Balance Remaining</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Repayments.Any())
                        {
                            <tr><td colspan="4" class="text-center text-muted py-3">No repayments recorded.</td></tr>
                        }
                        @foreach (var r in Model.Repayments.OrderByDescending(r => r.RepaymentDate))
                        {
                            <tr>
                                <td>@r.RepaymentId</td>
                                <td>@r.RepaymentDate.ToString("dd MMM yyyy")</td>
                                <td class="text-success fw-semibold">@r.AmountPaid.ToString("C")</td>
                                <td class="@(r.BalanceRemaining == 0 ? "text-success" : "text-danger") fw-semibold">
                                    @r.BalanceRemaining.ToString("C")
                                    @if (r.BalanceRemaining == 0)
                                    {
                                        <span class="badge bg-success ms-1">Paid Off</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
