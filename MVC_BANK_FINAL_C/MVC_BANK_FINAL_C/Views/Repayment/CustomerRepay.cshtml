@model MVC_BANK_FINAL_C.Models.ViewModels.RepaymentViewModel
@{
    ViewData["Title"] = "Make Loan Repayment";
    var loan = ViewBag.Loan as MVC_BANK_FINAL_C.Models.Entities.Loan;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6" style="max-width:560px;">

            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-cash-coin me-2"></i>Make Loan Repayment</h5>
                </div>
                <div class="card-body p-4">

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger py-2">@TempData["Error"]</div>
                    }

                    @if (ViewData.ModelState.ErrorCount > 0)
                    {
                        <div class="alert alert-danger py-2">
                            <div asp-validation-summary="ModelOnly"></div>
                        </div>
                    }

                    <!-- Loan summary (read-only) — formula details intentionally hidden -->
                    <div class="card bg-light border-0 mb-4">
                        <div class="card-body py-3">
                            <dl class="row mb-0 small">
                                <dt class="col-sm-6">Loan #</dt>
                                <dd class="col-sm-6">@Model.LoanId</dd>

                                <dt class="col-sm-6">Total Amount Due</dt>
                                <dd class="col-sm-6 fw-bold text-danger fs-6">
                                    @(Model.BalanceRemaining?.ToString("C") ?? "-")
                                </dd>

                                @if (loan != null)
                                {
                                    <dt class="col-sm-6">Suggested Monthly Payment</dt>
                                    <dd class="col-sm-6 fw-semibold">@loan.MonthlyEMI.ToString("C")</dd>
                                }
                            </dl>
                        </div>
                    </div>

                    <form asp-action="CustomerRepay" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="LoanId" />
                        <input type="hidden" asp-for="BalanceRemaining" />
                        <input type="hidden" asp-for="CustomerName" />

                        <!-- Account dropdown -->
                        <div class="mb-3">
                            <label asp-for="AccountId" class="form-label fw-semibold">Pay From Account</label>
                            <select asp-for="AccountId" asp-items="Model.AccountList" class="form-select">
                                <option value="">-- Select Account --</option>
                            </select>
                            <span asp-validation-for="AccountId" class="text-danger small"></span>
                        </div>

                        <!-- Amount -->
                        <div class="mb-3">
                            <label asp-for="AmountPaid" class="form-label fw-semibold">Repayment Amount</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="AmountPaid" class="form-control" type="number"
                                       step="0.01" min="0.01" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="AmountPaid" class="text-danger small"></span>
                            <div class="form-text text-muted">
                                Maximum payable: <strong>@(Model.BalanceRemaining?.ToString("C") ?? "-")</strong>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bi bi-check-circle me-1"></i>Make Repayment
                            </button>
                            <a asp-action="Index" asp-route-loanId="@Model.LoanId"
                               class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
