@model IEnumerable<MVC_BANK_FINAL_C.Models.Entities.AuditLog>
@{
    ViewData["Title"] = "Audit Logs";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Audit Logs</h2>
    <span class="badge bg-secondary fs-6">@Model.Count() entries</span>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Transaction ID</th>
                    <th>Account</th>
                    <th>Customer</th>
                    <th>Action Performed</th>
                    <th>Performed By</th>
                    <th>Log Date</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">No audit logs found.</td></tr>
                }
                @foreach (var log in Model)
                {
                    <tr>
                        <td>@log.LogId</td>
                        <td>@log.TransactionId</td>
                        <td>@(log.Transaction?.AccountId.ToString() ?? "-")</td>
                        <td>@(log.Transaction?.Account?.Customer?.Name ?? "-")</td>
                        <td>@log.ActionPerformed</td>
                        <td><span class="badge bg-secondary">@log.PerformedBy</span></td>
                        <td>@log.LogDate.ToString("dd MMM yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
