@model MVC_BANK_FINAL_C.Models.Entities.Customer
@{
    ViewData["Title"] = "Customer Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Customer Details</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.CustomerId" class="btn btn-outline-secondary">Edit</a>
        <a asp-action="Index" class="btn btn-outline-dark ms-2">Back to List</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white fw-semibold">Personal Information</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Customer ID</dt>
                    <dd class="col-sm-8">@Model.CustomerId</dd>
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Model.Name</dd>
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>
                    <dt class="col-sm-4">Contact</dt>
                    <dd class="col-sm-8">@(Model.ContactInfo ?? "-")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white fw-semibold d-flex justify-content-between align-items-center">
                <span>Accounts</span>
                @if (ViewBag.CanCreateAccount == true)
                {
                    <a asp-controller="Account" asp-action="Create" asp-route-customerId="@Model.CustomerId"
                       class="btn btn-sm btn-light">+ Add Account</a>
                }
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr><th>Account ID</th><th>Type</th><th>Balance</th></tr>
                    </thead>
                    <tbody>
                        @if (!Model.Accounts.Any())
                        {
                            <tr><td colspan="3" class="text-center text-muted py-3">No accounts found.</td></tr>
                        }
                        @foreach (var acc in Model.Accounts)
                        {
                            <tr>
                                <td>@acc.AccountId</td>
                                <td><span class="badge bg-info">@acc.AccountType</span></td>
                                <td class="fw-semibold">@acc.Balance.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card shadow-sm mt-3">
            <div class="card-header bg-warning fw-semibold">Loans</div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr><th>Loan ID</th><th>Amount</th><th>Rate</th><th>Status</th></tr>
                    </thead>
                    <tbody>
                        @if (!Model.Loans.Any())
                        {
                            <tr><td colspan="4" class="text-center text-muted py-3">No loans found.</td></tr>
                        }
                        @foreach (var loan in Model.Loans)
                        {
                            <tr>
                                <td>@loan.LoanId</td>
                                <td>@loan.LoanAmount.ToString("C")</td>
                                <td>@loan.InterestRate%</td>
                                <td>
                                    <span class="badge @(loan.LoanStatus == MVC_BANK_FINAL_C.Data.LoanStatus.APPROVED ? "bg-success" : loan.LoanStatus == MVC_BANK_FINAL_C.Data.LoanStatus.REJECTED ? "bg-danger" : "bg-secondary")">
                                        @loan.LoanStatus
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
