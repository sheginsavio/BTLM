@model MVC_BANK_FINAL_C.Models.Entities.Customer
@{
    ViewData["Title"] = "Customer Details";
    var isAdmin = ViewBag.IsAdmin == true;
    var culture = new System.Globalization.CultureInfo("en-IN");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Customer Details</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.CustomerId"
           class="btn btn-outline-secondary">Edit</a>
        <a asp-action="Index"
           class="btn btn-outline-dark ms-2">Back to List</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white fw-semibold">
                Personal Information
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Customer ID</dt>
                    <dd class="col-sm-8">@Model.CustomerId</dd>
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Model.Name</dd>
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>
                    <dt class="col-sm-4">Contact</dt>
                    <dd class="col-sm-8">@(Model.ContactInfo ?? "-")</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white fw-semibold
                         d-flex justify-content-between align-items-center">
                <span>Accounts</span>
                @if (ViewBag.CanCreateAccount == true)
                {
                    <a asp-controller="Account" asp-action="Create"
                       asp-route-customerId="@Model.CustomerId"
                       class="btn btn-sm btn-light">+ Add Account</a>
                }
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Account ID</th>
                            <th>Type</th>
                            <th>Balance</th>
                            @if (isAdmin)
                            {
                                <th>Actions</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Accounts.Any())
                        {
                            <tr>
                                <td colspan="@(isAdmin ? 4 : 3)"
                                    class="text-center text-muted py-3">
                                    No accounts found.
                                </td>
                            </tr>
                        }
                        @foreach (var acc in Model.Accounts)
                        {
                            <tr>
                                <td>@acc.AccountId</td>
                                <td>
                                    <span class="badge bg-info text-dark">
                                        @acc.AccountType
                                    </span>
                                </td>
                                <td class="fw-semibold">
                                    @acc.Balance.ToString("C", culture)
                                </td>
                                @if (isAdmin)
                                {
                                    <td>
                                        <button type="button"
                                                class="btn btn-danger btn-sm delete-account-btn"
                                                data-account-id="@acc.AccountId"
                                                data-customer-id="@Model.CustomerId"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteAccountModal">
                                            Delete
                                        </button>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card shadow-sm mt-3">
            <div class="card-header bg-warning fw-semibold">Loans</div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Loan ID</th>
                            <th>Amount</th>
                            <th>Rate</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Loans.Any())
                        {
                            <tr>
                                <td colspan="4"
                                    class="text-center text-muted py-3">
                                    No loans found.
                                </td>
                            </tr>
                        }
                        @foreach (var loan in Model.Loans)
                        {
                            <tr>
                                <td>@loan.LoanId</td>
                                <td>@loan.LoanAmount.ToString("C", culture)</td>
                                <td>@loan.InterestRate%</td>
                                <td>
                                    <span class="badge @(loan.LoanStatus == MVC_BANK_FINAL_C.Data.LoanStatus.APPROVED ? "bg-success" : loan.LoanStatus == MVC_BANK_FINAL_C.Data.LoanStatus.REJECTED ? "bg-danger" : "bg-secondary")">
                                        @loan.LoanStatus
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@if (isAdmin)
{
    <!-- Delete Account Confirmation Modal -->
    <div class="modal fade" id="deleteAccountModal" tabindex="-1"
         aria-labelledby="deleteModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="deleteModalLabel">
                        ⚠️ Confirm Account Deletion
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                            data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div id="deleteCheckMessage" class="text-center py-3">
                        <div class="spinner-border text-danger" role="status"></div>
                        <p class="mt-2">Checking account status...</p>
                    </div>
                    <div id="deleteAllowedContent" style="display:none;">
                        <div class="alert alert-danger">
                            <strong>This action cannot be undone!</strong>
                        </div>
                        <p>Are you sure you want to permanently delete
                           <strong id="deleteAccountLabel"></strong>?
                        </p>
                        <form id="deleteAccountForm" method="post"
                              asp-controller="Account" asp-action="Delete">
                            @Html.AntiForgeryToken()
                            <input type="hidden" id="deleteAccountId"
                                   name="accountId" />
                            <input type="hidden" id="deleteCustomerId"
                                   name="customerId"
                                   value="@Model.CustomerId" />
                        </form>
                    </div>
                    <div id="deleteBlockedContent" style="display:none;">
                        <div class="alert alert-warning"
                             id="deleteBlockedReason"></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger"
                            id="confirmDeleteBtn" style="display:none;"
                            onclick="document.getElementById('deleteAccountForm').submit()">
                        Yes, Delete Permanently
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.querySelectorAll('.delete-account-btn')
            .forEach(function (btn) {
            btn.addEventListener('click', function () {
                var accountId  = this.getAttribute('data-account-id');
                var customerId = this.getAttribute('data-customer-id');

                // Reset modal state
                document.getElementById('deleteCheckMessage')
                    .style.display  = 'block';
                document.getElementById('deleteAllowedContent')
                    .style.display  = 'none';
                document.getElementById('deleteBlockedContent')
                    .style.display  = 'none';
                document.getElementById('confirmDeleteBtn')
                    .style.display  = 'none';

                // Set hidden inputs
                document.getElementById('deleteAccountId').value  = accountId;
                document.getElementById('deleteCustomerId').value = customerId;

                // Check if account can be deleted
                fetch('/Account/CanDelete?accountId=' + accountId)
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        document.getElementById('deleteCheckMessage')
                            .style.display = 'none';

                        if (data.canDelete) {
                            document.getElementById('deleteAccountLabel')
                                .textContent = 'Account #' + accountId;
                            document.getElementById('deleteAllowedContent')
                                .style.display = 'block';
                            document.getElementById('confirmDeleteBtn')
                                .style.display = 'inline-block';
                        } else {
                            document.getElementById('deleteBlockedReason')
                                .textContent = data.reason;
                            document.getElementById('deleteBlockedContent')
                                .style.display = 'block';
                        }
                    })
                    .catch(function () {
                        document.getElementById('deleteCheckMessage')
                            .style.display = 'none';
                        document.getElementById('deleteBlockedReason')
                            .textContent =
                            'Unable to check account status. Please try again.';
                        document.getElementById('deleteBlockedContent')
                            .style.display = 'block';
                    });
            });
        });
    </script>
}
