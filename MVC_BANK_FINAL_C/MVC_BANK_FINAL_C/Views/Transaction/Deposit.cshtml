@model MVC_BANK_FINAL_C.Models.ViewModels.TransactionViewModel
@{
    ViewData["Title"] = "Deposit Funds";
    bool isCustomer = ViewBag.ShowCustomerSearch == false;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">

            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white py-3">
                    <h4 class="mb-0"><i class="bi bi-cash-coin me-2"></i>Deposit Funds</h4>
                </div>
                <div class="card-body p-4">

                    @if (ViewData.ModelState.ErrorCount > 0)
                    {
                        <div class="alert alert-danger py-2">
                            <div asp-validation-summary="ModelOnly"></div>
                        </div>
                    }

                    <form asp-action="Deposit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="TransactionType" />
                        <input type="hidden" asp-for="PerformedBy" />

                        @if (!isCustomer)
                        {
                            <!-- SECTION A: Admin / Teller — customer search then account dropdown -->
                            <div class="mb-3 position-relative">
                                <label class="form-label fw-semibold">Search Customer</label>
                                <input type="text" id="customerSearch" class="form-control"
                                       placeholder="Type customer name or email…" autocomplete="off" />
                                <ul id="customerSuggestions"
                                    class="list-group position-absolute z-3"
                                    style="width:100%;max-height:200px;overflow-y:auto;display:none;top:100%;left:0;"></ul>
                            </div>

                            <div class="mb-3" id="accountSection" style="display:none;">
                                <label class="form-label fw-semibold">Select Account</label>
                                <select id="accountSelect" asp-for="AccountId" class="form-select">
                                    <option value="">-- Select Account --</option>
                                </select>
                                <span asp-validation-for="AccountId" class="text-danger small"></span>
                            </div>
                        }
                        else
                        {
                            <!-- SECTION B: Customer — pre-populated own-account dropdown -->
                            <div class="mb-3">
                                <label asp-for="AccountId" class="form-label fw-semibold">Select Your Account</label>
                                <select asp-for="AccountId" asp-items="Model.FromAccountList" class="form-select">
                                    <option value="">-- Select Account --</option>
                                </select>
                                <span asp-validation-for="AccountId" class="text-danger small"></span>
                            </div>
                        }

                        <div class="mb-3">
                            <label asp-for="Amount" class="form-label fw-semibold">Amount</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="Amount" class="form-control" type="number"
                                       step="0.01" min="0.01" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="Amount" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bi bi-check-circle me-1"></i>Deposit
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@if (!isCustomer)
{
    <script>
    (function () {
        const searchInput    = document.getElementById('customerSearch');
        const suggestions    = document.getElementById('customerSuggestions');
        const accountSection = document.getElementById('accountSection');
        const accountSelect  = document.getElementById('accountSelect');
        let debounce;

        searchInput.addEventListener('input', function () {
            clearTimeout(debounce);
            const term = this.value.trim();
            if (term.length < 2) { suggestions.style.display = 'none'; return; }
            debounce = setTimeout(() => fetchCustomers(term), 300);
        });

        function fetchCustomers(term) {
            fetch('/Customer/SearchCustomer?term=' + encodeURIComponent(term))
                .then(r => r.json())
                .then(data => {
                    suggestions.innerHTML = '';
                    if (!data || data.length === 0) { suggestions.style.display = 'none'; return; }
                    data.forEach(c => {
                        const li = document.createElement('li');
                        li.className = 'list-group-item list-group-item-action cursor-pointer';
                        li.textContent = c.name + ' — ' + c.email;
                        li.addEventListener('click', () => selectCustomer(c));
                        suggestions.appendChild(li);
                    });
                    suggestions.style.display = 'block';
                })
                .catch(() => { suggestions.style.display = 'none'; });
        }

        function selectCustomer(c) {
            searchInput.value = c.name + ' (' + c.email + ')';
            suggestions.style.display = 'none';
            loadAccounts(c.customerId);
        }

        function loadAccounts(customerId) {
            fetch('/Transaction/GetCustomerAccounts?customerId=' + customerId)
                .then(r => r.json())
                .then(data => {
                    accountSelect.innerHTML = '<option value="">-- Select Account --</option>';
                    if (data.success && data.accounts && data.accounts.length > 0) {
                        data.accounts.forEach(a => {
                            const opt = document.createElement('option');
                            opt.value       = a.accountId;
                            opt.textContent = a.label;
                            accountSelect.appendChild(opt);
                        });
                        accountSection.style.display = 'block';
                    } else {
                        accountSection.style.display = 'none';
                    }
                })
                .catch(() => { accountSection.style.display = 'none'; });
        }

        document.addEventListener('click', function (e) {
            if (!suggestions.contains(e.target) && e.target !== searchInput) {
                suggestions.style.display = 'none';
            }
        });
    })();
    </script>
}

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
