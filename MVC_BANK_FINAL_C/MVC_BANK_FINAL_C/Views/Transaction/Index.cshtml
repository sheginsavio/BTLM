@model IEnumerable<MVC_BANK_FINAL_C.Models.Entities.Transaction>
@{
    ViewData["Title"] = "Transactions";
    string userRole = ViewBag.UserRole ?? "";
    bool canTransact = userRole == "Admin" || userRole == "Teller" || userRole == "Customer";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Transactions</h2>

    @if (canTransact)
    {
        <div class="btn-group">
            @if (userRole == "Admin" || userRole == "Teller")
            {
                <a asp-action="Deposit" class="btn btn-success">
                    <i class="bi bi-cash-coin me-1"></i>Deposit
                </a>
            }
            <a asp-action="Withdraw" class="btn btn-warning">
                <i class="bi bi-cash-stack me-1"></i>Withdraw
            </a>
            <a asp-action="Transfer" class="btn btn-info">
                <i class="bi bi-arrow-left-right me-1"></i>Transfer
            </a>
        </div>
    }
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Account ID</th>
                    <th>Customer</th>
                    <th>Type</th>
                    <th>Amount</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">No transactions found.</td>
                    </tr>
                }
                @foreach (var t in Model)
                {
                    <tr>
                        <td>@t.TransactionId</td>
                        <td>@t.AccountId</td>
                        <td>@(t.Account?.Customer?.Name ?? "-")</td>
                        <td>
                            @{
                                string badgeClass = t.TransactionType switch
                                {
                                    MVC_BANK_FINAL_C.Data.TransactionType.DEPOSIT    => "bg-success",
                                    MVC_BANK_FINAL_C.Data.TransactionType.WITHDRAWAL => "bg-warning text-dark",
                                    _                                                => "bg-info text-dark"
                                };
                            }
                            <span class="badge @badgeClass">@t.TransactionType</span>
                        </td>
                        <td class="fw-semibold">@t.Amount.ToString("C")</td>
                        <td>@t.TransactionDate.ToString("dd MMM yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
